{
  "name": "personal-dashboard-landing-page",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "lint:js": "eslint \"assets/js/**/*.js\" \"services/**/*.js\"",
    "lint:js:fix": "eslint --fix \"assets/js/**/*.js\" \"services/**/*.js\"",
    "lint:css": "stylelint \"assets/css/*.css\"",
    "lint:css:fix": "stylelint --fix \"assets/css/*.css\"",
    "lint:html": "htmlhint index.html options.html"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "htmlhint": "^1.9.2",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
