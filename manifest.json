{
  "manifest_version": 3,
  "name": "BarkBoard - Personal Dashboard",
  "version": "1.0",
  "description": "Personal stats dashboard on new tab.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "personal-dashboard@wolfpaw"
    }
  },
  "data_collection_permissions": {
    "required": [],
    "optional": []
  }
}
